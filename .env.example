# Required for the AI scheduler soft pass and (phase 2) chat.
# Without it the app still runs; the scheduler uses the deterministic baseline plan.
ANTHROPIC_API_KEY=

# Set by docker-compose; when unset locally the server uses embedded PGlite at .pglite-data/
DATABASE_URL=

# Postgres credentials used by docker-compose
POSTGRES_USER=vdv
POSTGRES_PASSWORD=vdv
POSTGRES_DB=vdv
